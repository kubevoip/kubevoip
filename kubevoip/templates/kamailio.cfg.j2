#!KAMAILIO
#!define ADVERTISED_ADDR "{{ external_address }}"
#!define INTERNAL_ADDR "{{ internal_address }}"
#!define AUTH_REALM "{{ auth_realm }}"
#!define RTPENGINE_SOCKETS "{{ relay_sockets }}"
#!define KUBEVOIP_NAMESPACE "{{ namespace }}"
#!define KUBEVOIP_GATEWAY "{{ gateway_name }}"
auto_aliases=no
log_stderror=yes
debug=2
alias=ADVERTISED_ADDR:5060
alias=INTERNAL_ADDR:5060
listen=udp:0.0.0.0:5060 advertise ADVERTISED_ADDR:5060
loadmodule "db_postgres.so"
loadmodule "tm.so"
loadmodule "sl.so"
loadmodule "rr.so"
loadmodule "pv.so"
loadmodule "maxfwd.so"
loadmodule "textops.so"
loadmodule "siputils.so"
loadmodule "auth.so"
loadmodule "auth_db.so"
loadmodule "usrloc.so"
loadmodule "registrar.so"
loadmodule "sqlops.so"
loadmodule "uac.so"
loadmodule "dialog.so"
loadmodule "rtpengine.so"
loadmodule "xlog.so"
{% if capture.enabled %}
loadmodule "siptrace.so"
{% endif %}
modparam("usrloc", "db_mode", 3)
modparam("usrloc", "db_url", "__DBURL__")
modparam("auth_db", "db_url", "__DBURL__")
modparam("auth_db", "password_column", "ha1")
modparam("auth_db", "calculate_ha1", 0)
modparam("uac", "auth_username_avp", "$avp(auser)")
modparam("uac", "auth_password_avp", "$avp(apass)")
modparam("uac", "auth_realm_avp", "$avp(arealm)")
modparam("rtpengine", "rtpengine_sock", RTPENGINE_SOCKETS)
modparam("sqlops", "sqlcon", "kubevoip=>__DBURL__")
{% if capture.enabled %}
modparam("siptrace", "trace_on", 1)
modparam("siptrace", "trace_to_database", 0)
modparam("siptrace", "hep_mode_on", 1)
modparam("siptrace", "hep_version", 3)
modparam("siptrace", "duplicate_uri", "{{ hep_destination }}")
{% endif %}

request_route {
{% if capture.enabled %}
  sip_trace_mode("{{ capture_mode }}");
{% endif %}
  xlog("L_INFO", "kubevoip_sip_event namespace={{ namespace }} gateway={{ gateway_name }} stage=request method=$rm call_id=$ci source=$si target=$rU\n");
{% if sip_headers.enabled %}
  route(LOG_SIP_MESSAGE);
{% endif %}
  if (!mf_process_maxfwd_header("10")) { send_reply("483", "Too Many Hops"); exit; }
  route(DETECT_TRUSTED_TRUNK);
  if (is_method("BYE|CANCEL")) {
    xlog("L_INFO", "kubevoip_sip_event namespace={{ namespace }} gateway={{ gateway_name }} stage=rtpengine_delete method=$rm call_id=$ci source=$si\n");
    rtpengine_delete();
  }
  if (has_totag()) {
    if (loose_route()) { route(RELAY); exit; }
    if (is_method("ACK")) { exit; }
    xlog("L_WARN", "kubevoip_sip_event namespace={{ namespace }} gateway={{ gateway_name }} stage=dialog_not_found method=$rm call_id=$ci source=$si\n");
    send_reply("404", "Dialog not found");
    exit;
  }
  if (is_method("REGISTER")) {
    if (!www_authorize(AUTH_REALM, "subscriber")) {
      xlog("L_INFO", "kubevoip_sip_event namespace={{ namespace }} gateway={{ gateway_name }} stage=register_challenge call_id=$ci source=$si\n");
      www_challenge(AUTH_REALM, "0");
      exit;
    }
    save("location");
    xlog("L_INFO", "kubevoip_sip_event namespace={{ namespace }} gateway={{ gateway_name }} stage=register_saved call_id=$ci source=$si user=$aU\n");
    exit;
  }
  if (is_method("INVITE") && !isflagset(1)) {
    if (!proxy_authorize(AUTH_REALM, "subscriber")) {
      xlog("L_INFO", "kubevoip_sip_event namespace={{ namespace }} gateway={{ gateway_name }} stage=invite_challenge call_id=$ci source=$si target=$rU\n");
      proxy_challenge(AUTH_REALM, "0");
      exit;
    }
    route(LOAD_AUTHENTICATED_POLICY);
    consume_credentials();
  }
  if (is_method("INVITE") && $avp(caller_policy) == $null) {
    xlog("L_WARN", "kubevoip_sip_event namespace={{ namespace }} gateway={{ gateway_name }} stage=no_dial_policy call_id=$ci source=$si target=$rU\n");
    send_reply("403", "No dial policy");
    exit;
  }
  if (!($rU =~ "^[+0-9.*]+$")) {
    xlog("L_WARN", "kubevoip_sip_event namespace={{ namespace }} gateway={{ gateway_name }} stage=invalid_target call_id=$ci source=$si target=$rU\n");
    send_reply("404", "No route");
    exit;
  }
  if (has_body("application/sdp")) {
    xlog("L_INFO", "kubevoip_sip_event namespace={{ namespace }} gateway={{ gateway_name }} stage=rtpengine_offer call_id=$ci source=$si target=$rU\n");
    rtpengine_offer("replace-origin replace-session-connection");
  }
  if (is_method("INVITE")) { dlg_manage(); {{ record_route_line }} }
  route(ROUTE_INVITE);
  exit;
}

route[DETECT_TRUSTED_TRUNK] {
  $var(trusted_query) = "{{ trusted_query_prefix }}" + $si + "{{ trusted_query_suffix }}";
  sql_query("kubevoip", "$var(trusted_query)", "trusted");
  if ($dbr(trusted=>rows) > 0) {
    setflag(1);
    $avp(caller_policy) = $dbr(trusted=>[0,1]);
    xlog("L_INFO", "kubevoip_sip_event namespace={{ namespace }} gateway={{ gateway_name }} stage=trusted_trunk_matched call_id=$ci source=$si\n");
  }
  sql_result_free("trusted");
}

route[LOAD_AUTHENTICATED_POLICY] {
  $var(caller_query) = "{{ caller_query_prefix }}" + $aU + "{{ caller_query_suffix }}";
  sql_query("kubevoip", "$var(caller_query)", "caller");
  if ($dbr(caller=>rows) > 0) {
    $avp(caller_policy) = $dbr(caller=>[0,0]);
    xlog("L_INFO", "kubevoip_sip_event namespace={{ namespace }} gateway={{ gateway_name }} stage=authenticated_policy_loaded call_id=$ci source=$si user=$aU\n");
  }
  sql_result_free("caller");
}

route[ROUTE_INVITE] {
  $var(route_query) = "{{ route_query_prefix }}" + $avp(caller_policy) + "{{ route_query_middle }}" + $rU + "{{ route_query_suffix }}" + $rU + "{{ route_query_end }}";
  sql_query("kubevoip", "$var(route_query)", "route");
  if ($dbr(route=>rows) == 0) {
    sql_result_free("route");
    xlog("L_WARN", "kubevoip_sip_event namespace={{ namespace }} gateway={{ gateway_name }} stage=no_permitted_route call_id=$ci source=$si target=$rU\n");
    send_reply("403", "No permitted route");
    exit;
  }
  $avp(target_kind) = $dbr(route=>[0,0]);
  xlog("L_INFO", "kubevoip_sip_event namespace={{ namespace }} gateway={{ gateway_name }} stage=route_selected call_id=$ci source=$si target=$rU target_kind=$avp(target_kind)\n");
  if ($avp(target_kind) == "SIPUser") {
    $rU = $dbr(route=>[0,4]);
    sql_result_free("route");
    if (!lookup("location")) { send_reply("404", "Not registered"); exit; }
    route(RELAY);
    exit;
  }
  if ($avp(target_kind) == "AsteriskPool") {
    $rU = $dbr(route=>[0,2]);
    $du = "sip:" + $dbr(route=>[0,3]) + ":5060";
    sql_result_free("route");
    route(RELAY);
    exit;
  }
  if ($avp(target_kind) == "SIPTrunk") {
    remove_hf("Route");
    if ($dbr(route=>[0,6]) != "") {
      uac_replace_from($dbr(route=>[0,6]), "sip:" + $dbr(route=>[0,6]) + "@ADVERTISED_ADDR");
    }
    $rd = $dbr(route=>[0,5]);
    $du = "sip:" + $dbr(route=>[0,5]);
    $avp(auser) = $dbr(route=>[0,7]);
    $avp(arealm) = $dbr(route=>[0,8]);
    $avp(apass) = $dbr(route=>[0,9]);
    sql_result_free("route");
    route(RELAY_TRUNK);
    exit;
  }
  sql_result_free("route");
  xlog("L_ERR", "kubevoip_sip_event namespace={{ namespace }} gateway={{ gateway_name }} stage=unsupported_route_target call_id=$ci target_kind=$avp(target_kind)\n");
  send_reply("500", "Unsupported route target");
  exit;
}

route[RELAY] {
  t_on_reply("MANAGE_REPLY");
  if (!t_relay()) {
    xlog("L_ERR", "kubevoip_sip_event namespace={{ namespace }} gateway={{ gateway_name }} stage=relay_failed call_id=$ci method=$rm target=$rU\n");
    sl_reply_error();
  }
  exit;
}

route[RELAY_TRUNK] {
  t_on_reply("MANAGE_REPLY");
  t_on_failure("TRUNK_AUTH");
  if (!t_relay()) {
    xlog("L_ERR", "kubevoip_sip_event namespace={{ namespace }} gateway={{ gateway_name }} stage=trunk_relay_failed call_id=$ci method=$rm target=$rU\n");
    sl_reply_error();
  }
  exit;
}

failure_route[TRUNK_AUTH] {
  if (t_is_canceled()) { exit; }
  if (t_check_status("401|407") && $avp(auser) != "" && $avp(apass) != "") {
    xlog("L_INFO", "kubevoip_sip_event namespace={{ namespace }} gateway={{ gateway_name }} stage=trunk_auth_retry call_id=$ci\n");
    if (uac_auth_mode("1")) { t_relay(); exit; }
  }
}

{% if sip_headers.enabled %}
route[LOG_SIP_MESSAGE] {
  $var(headers) = $(msg(hdrs){s.replace,\r,\\r}{s.replace,\n,\\n});
{% if sdp.enabled %}
  $var(sdp) = "";
  if (has_body("application/sdp")) {
    $var(sdp) = $(rb{s.replace,\r,\\r}{s.replace,\n,\\n});
  }
  xlog("L_INFO", "kubevoip_sip_message namespace={{ namespace }} gateway={{ gateway_name }} direction=$mt method=$rm status=$rs call_id=$ci source=$si first_line=[$msg(fline)] headers=[$var(headers)] sdp=[$var(sdp)]\n");
{% else %}
  xlog("L_INFO", "kubevoip_sip_message namespace={{ namespace }} gateway={{ gateway_name }} direction=$mt method=$rm status=$rs call_id=$ci source=$si first_line=[$msg(fline)] headers=[$var(headers)] sdp=[]\n");
{% endif %}
}

{% endif %}
onreply_route[MANAGE_REPLY] {
{% if sip_headers.enabled %}
  route(LOG_SIP_MESSAGE);
{% endif %}
  if (has_body("application/sdp")) {
    xlog("L_INFO", "kubevoip_sip_event namespace={{ namespace }} gateway={{ gateway_name }} stage=rtpengine_answer call_id=$ci status=$rs\n");
    rtpengine_answer("replace-origin replace-session-connection");
  }
}
